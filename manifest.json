{
  "manifest_version": 3,
  "name": "OptiChrome Pro",
  "version": "2.1",
  "description": "Optimización de RAM y acelerador de sitios. Proyecto OpenSource desarrollado por José T. Moya.",
  "permissions": ["tabs", "storage", "alarms"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["optimizaciones/youtube.js"],
      "run_at": "document_start"
    }
  ]
}